<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Table Tennis</title>
  <style>
    :root {
      --ink: #f6f7f2;
      --muted: rgba(246, 247, 242, 0.68);
      --line: rgba(246, 247, 242, 0.16);
      --table: #123f39;
      --table-dark: #0a2825;
      --accent: #d7b46a;
      --surface: rgba(255, 255, 255, 0.08);
      --surface-strong: rgba(255, 255, 255, 0.14);
      --danger: #ff7a66;
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      min-height: 100%;
      margin: 0;
    }

    body {
      display: grid;
      place-items: center;
      padding: 24px;
      overflow-x: hidden;
      background:
        radial-gradient(circle at 20% 8%, rgba(215, 180, 106, 0.18), transparent 28%),
        radial-gradient(circle at 82% 18%, rgba(77, 184, 168, 0.14), transparent 30%),
        linear-gradient(145deg, #071412, #0c201e 52%, #091817);
      color: var(--ink);
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "SF Pro Text", "Segoe UI", system-ui, sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    .app {
      width: min(1120px, 100%);
      display: grid;
      gap: 18px;
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
    }

    .brand {
      display: grid;
      gap: 2px;
    }

    .brand span {
      color: var(--muted);
      font-size: 0.78rem;
      font-weight: 760;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      font-size: clamp(2rem, 6vw, 4.4rem);
      line-height: 0.94;
      letter-spacing: -0.07em;
    }

    .scoreboard {
      display: grid;
      grid-template-columns: repeat(3, auto);
      align-items: center;
      gap: 12px;
      padding: 10px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--surface);
      backdrop-filter: blur(18px) saturate(1.35);
      -webkit-backdrop-filter: blur(18px) saturate(1.35);
    }

    .score-card {
      min-width: 82px;
      padding: 7px 12px;
      text-align: center;
    }

    .score-card span {
      display: block;
      color: var(--muted);
      font-size: 0.7rem;
      font-weight: 760;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .score-card strong {
      display: block;
      font-size: 2rem;
      line-height: 1;
      letter-spacing: -0.05em;
    }

    .score-divider {
      width: 1px;
      height: 42px;
      background: var(--line);
    }

    .stage {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(246, 247, 242, 0.2);
      border-radius: 28px;
      background:
        linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px),
        linear-gradient(180deg, var(--table), var(--table-dark));
      box-shadow: 0 36px 90px rgba(0, 0, 0, 0.36), inset 0 1px 0 rgba(255, 255, 255, 0.2);
    }

    canvas {
      width: 100%;
      aspect-ratio: 16 / 9;
      display: block;
      cursor: none;
    }

    .status {
      position: absolute;
      left: 50%;
      top: 18px;
      transform: translateX(-50%);
      max-width: calc(100% - 32px);
      padding: 9px 14px;
      border: 1px solid rgba(246, 247, 242, 0.18);
      border-radius: 999px;
      background: rgba(7, 20, 18, 0.54);
      color: var(--ink);
      box-shadow: 0 14px 30px rgba(0, 0, 0, 0.18);
      backdrop-filter: blur(18px) saturate(1.4);
      -webkit-backdrop-filter: blur(18px) saturate(1.4);
      font-size: 0.92rem;
      font-weight: 720;
      letter-spacing: -0.02em;
      text-align: center;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      pointer-events: none;
    }

    .controls {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 14px;
      align-items: center;
    }

    .hints {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .hint,
    button,
    select {
      min-height: 38px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--surface);
      color: var(--ink);
      font-size: 0.9rem;
      font-weight: 680;
      letter-spacing: -0.01em;
    }

    .hint {
      display: inline-flex;
      align-items: center;
      padding: 0 13px;
      color: var(--muted);
    }

    .actions {
      display: flex;
      gap: 8px;
      align-items: center;
      justify-content: flex-end;
    }

    button,
    select {
      padding: 0 14px;
      appearance: none;
      cursor: pointer;
    }

    button:hover,
    button:focus-visible,
    select:hover,
    select:focus-visible {
      background: var(--surface-strong);
      outline: none;
    }

    .primary {
      border-color: rgba(215, 180, 106, 0.42);
      background: rgba(215, 180, 106, 0.18);
      color: #fff8df;
    }

    @media (max-width: 760px) {
      body {
        padding: 14px;
      }

      .topbar,
      .controls {
        grid-template-columns: 1fr;
        display: grid;
      }

      .scoreboard,
      .actions {
        justify-self: stretch;
        justify-content: center;
      }

      .scoreboard {
        grid-template-columns: 1fr auto 1fr;
      }

      .stage {
        border-radius: 20px;
      }

      canvas {
        aspect-ratio: 4 / 5;
      }

      .hints {
        justify-content: center;
      }

      .actions {
        flex-wrap: wrap;
      }
    }
  </style>
</head>
<body>
  <main class="app">
    <header class="topbar">
      <div class="brand">
        <span>Arcade match</span>
        <h1>Table Tennis</h1>
      </div>

      <section class="scoreboard" aria-label="Scoreboard">
        <div class="score-card">
          <span>You</span>
          <strong id="playerScore">0</strong>
        </div>
        <div class="score-divider" aria-hidden="true"></div>
        <div class="score-card">
          <span>Computer</span>
          <strong id="computerScore">0</strong>
        </div>
      </section>
    </header>

    <section class="stage" aria-label="Table tennis game area">
      <div id="status" class="status">Press Space to serve</div>
      <canvas id="game" width="1280" height="720" aria-label="Playable table tennis game"></canvas>
    </section>

    <section class="controls" aria-label="Game controls">
      <div class="hints">
        <span class="hint">Move: Mouse, touch, W/S, or arrow keys</span>
        <span class="hint">Pause: Space</span>
        <span class="hint">First to 7 wins</span>
      </div>

      <div class="actions">
        <select id="difficulty" aria-label="Difficulty">
          <option value="0.075">Easy</option>
          <option value="0.105" selected>Normal</option>
          <option value="0.138">Hard</option>
        </select>
        <button type="button" id="reset">Reset</button>
        <button type="button" id="serve" class="primary">Serve</button>
      </div>
    </section>
  </main>

  <script>
    const canvas = document.getElementById('game');
    const ctx = canvas.getContext('2d');
    const playerScoreEl = document.getElementById('playerScore');
    const computerScoreEl = document.getElementById('computerScore');
    const statusEl = document.getElementById('status');
    const serveButton = document.getElementById('serve');
    const resetButton = document.getElementById('reset');
    const difficultyEl = document.getElementById('difficulty');

    const state = {
      running: false,
      gameOver: false,
      playerScore: 0,
      computerScore: 0,
      keys: new Set(),
      aiSpeed: Number(difficultyEl.value),
      player: { x: 0, y: 0, w: 16, h: 112, targetY: 0 },
      computer: { x: 0, y: 0, w: 16, h: 112 },
      ball: { x: 0, y: 0, r: 10, vx: 0, vy: 0, speed: 7.5 }
    };

    function fitCanvas() {
      const rect = canvas.getBoundingClientRect();
      const scale = window.devicePixelRatio || 1;
      canvas.width = Math.round(rect.width * scale);
      canvas.height = Math.round(rect.height * scale);
      ctx.setTransform(scale, 0, 0, scale, 0, 0);
      resetPositions(false);
    }

    function width() {
      return canvas.getBoundingClientRect().width;
    }

    function height() {
      return canvas.getBoundingClientRect().height;
    }

    function clamp(value, min, max) {
      return Math.max(min, Math.min(max, value));
    }

    function resetPositions(centerPlayer = true) {
      const w = width();
      const h = height();
      state.player.x = 28;
      state.player.h = Math.max(80, h * 0.16);
      state.player.y = centerPlayer ? (h - state.player.h) / 2 : clamp(state.player.y, 16, h - state.player.h - 16);
      state.player.targetY = state.player.y;

      state.computer.w = state.player.w;
      state.computer.h = state.player.h;
      state.computer.x = w - state.computer.w - 28;
      state.computer.y = centerPlayer ? (h - state.computer.h) / 2 : clamp(state.computer.y, 16, h - state.computer.h - 16);

      state.ball.x = w / 2;
      state.ball.y = h / 2;
      state.ball.r = Math.max(8, Math.min(12, w * 0.012));
      draw();
    }

    function serve(direction = Math.random() > 0.5 ? 1 : -1) {
      if (state.gameOver) resetGame();
      state.running = true;
      state.ball.x = width() / 2;
      state.ball.y = height() / 2;
      state.ball.speed = Math.max(6.8, width() * 0.008);
      state.ball.vx = direction * state.ball.speed;
      state.ball.vy = (Math.random() * 2 - 1) * state.ball.speed * 0.62;
      statusEl.textContent = 'Playing';
    }

    function resetGame() {
      state.running = false;
      state.gameOver = false;
      state.playerScore = 0;
      state.computerScore = 0;
      playerScoreEl.textContent = '0';
      computerScoreEl.textContent = '0';
      resetPositions(true);
      statusEl.textContent = 'Press Space to serve';
    }

    function score(pointForPlayer) {
      state.running = false;
      if (pointForPlayer) {
        state.playerScore += 1;
        playerScoreEl.textContent = state.playerScore;
      } else {
        state.computerScore += 1;
        computerScoreEl.textContent = state.computerScore;
      }

      if (state.playerScore >= 7 || state.computerScore >= 7) {
        state.gameOver = true;
        statusEl.textContent = state.playerScore > state.computerScore ? 'You win. Reset for another match.' : 'Computer wins. Reset for another match.';
      } else {
        statusEl.textContent = pointForPlayer ? 'Point to you. Serve again.' : 'Point to computer. Serve again.';
      }

      resetPositions(false);
    }

    function movePlayer() {
      const h = height();
      const speed = h * 0.018;

      if (state.keys.has('arrowup') || state.keys.has('w')) {
        state.player.targetY -= speed;
      }
      if (state.keys.has('arrowdown') || state.keys.has('s')) {
        state.player.targetY += speed;
      }

      state.player.targetY = clamp(state.player.targetY, 16, h - state.player.h - 16);
      state.player.y += (state.player.targetY - state.player.y) * 0.34;
    }

    function moveComputer() {
      const h = height();
      const paddleCenter = state.computer.y + state.computer.h / 2;
      const prediction = state.ball.y + state.ball.vy * 8;
      const target = clamp(prediction, state.computer.h / 2 + 16, h - state.computer.h / 2 - 16);
      state.computer.y += (target - paddleCenter) * state.aiSpeed;
      state.computer.y = clamp(state.computer.y, 16, h - state.computer.h - 16);
    }

    function hitPaddle(paddle, side) {
      const ball = state.ball;
      const withinY = ball.y + ball.r > paddle.y && ball.y - ball.r < paddle.y + paddle.h;
      const withinX = side === 'left'
        ? ball.x - ball.r < paddle.x + paddle.w && ball.x > paddle.x
        : ball.x + ball.r > paddle.x && ball.x < paddle.x + paddle.w;

      if (!withinX || !withinY) return;

      const relative = (ball.y - (paddle.y + paddle.h / 2)) / (paddle.h / 2);
      ball.speed = Math.min(ball.speed + 0.38, width() * 0.016);
      ball.vx = (side === 'left' ? 1 : -1) * ball.speed;
      ball.vy = relative * ball.speed * 0.92;
      ball.x = side === 'left' ? paddle.x + paddle.w + ball.r : paddle.x - ball.r;
    }

    function update() {
      if (!state.running) return;

      const w = width();
      const h = height();
      const ball = state.ball;

      movePlayer();
      moveComputer();

      ball.x += ball.vx;
      ball.y += ball.vy;

      if (ball.y - ball.r <= 10 || ball.y + ball.r >= h - 10) {
        ball.vy *= -1;
        ball.y = clamp(ball.y, 10 + ball.r, h - 10 - ball.r);
      }

      hitPaddle(state.player, 'left');
      hitPaddle(state.computer, 'right');

      if (ball.x < -ball.r) score(false);
      if (ball.x > w + ball.r) score(true);
    }

    function drawTable(w, h) {
      ctx.clearRect(0, 0, w, h);
      ctx.fillStyle = '#123f39';
      ctx.fillRect(0, 0, w, h);

      ctx.strokeStyle = 'rgba(246,247,242,0.48)';
      ctx.lineWidth = 2;
      ctx.strokeRect(14, 14, w - 28, h - 28);

      ctx.setLineDash([12, 16]);
      ctx.beginPath();
      ctx.moveTo(w / 2, 14);
      ctx.lineTo(w / 2, h - 14);
      ctx.stroke();
      ctx.setLineDash([]);

      ctx.strokeStyle = 'rgba(246,247,242,0.18)';
      ctx.beginPath();
      ctx.moveTo(14, h / 2);
      ctx.lineTo(w - 14, h / 2);
      ctx.stroke();
    }

    function drawPaddle(paddle, color) {
      ctx.fillStyle = color;
      roundRect(paddle.x, paddle.y, paddle.w, paddle.h, 999);
      ctx.fill();
    }

    function roundRect(x, y, w, h, radius) {
      const r = Math.min(radius, w / 2, h / 2);
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.arcTo(x + w, y, x + w, y + h, r);
      ctx.arcTo(x + w, y + h, x, y + h, r);
      ctx.arcTo(x, y + h, x, y, r);
      ctx.arcTo(x, y, x + w, y, r);
      ctx.closePath();
    }

    function draw() {
      const w = width();
      const h = height();
      drawTable(w, h);
      drawPaddle(state.player, '#fff8df');
      drawPaddle(state.computer, '#d7b46a');

      ctx.beginPath();
      ctx.fillStyle = '#fff';
      ctx.shadowColor = 'rgba(255,255,255,0.55)';
      ctx.shadowBlur = 16;
      ctx.arc(state.ball.x, state.ball.y, state.ball.r, 0, Math.PI * 2);
      ctx.fill();
      ctx.shadowBlur = 0;
    }

    function loop() {
      update();
      draw();
      requestAnimationFrame(loop);
    }

    function pointerToPaddle(event) {
      const rect = canvas.getBoundingClientRect();
      const y = event.clientY - rect.top;
      state.player.targetY = clamp(y - state.player.h / 2, 16, height() - state.player.h - 16);
    }

    window.addEventListener('resize', fitCanvas);
    window.addEventListener('keydown', (event) => {
      const key = event.key.toLowerCase();
      state.keys.add(key);
      if (key === ' ') {
        event.preventDefault();
        if (state.running) {
          state.running = false;
          statusEl.textContent = 'Paused';
        } else {
          serve();
        }
      }
    });
    window.addEventListener('keyup', (event) => state.keys.delete(event.key.toLowerCase()));
    canvas.addEventListener('pointermove', pointerToPaddle);
    canvas.addEventListener('pointerdown', (event) => {
      pointerToPaddle(event);
      if (!state.running) serve();
    });
    serveButton.addEventListener('click', () => serve());
    resetButton.addEventListener('click', resetGame);
    difficultyEl.addEventListener('change', () => {
      state.aiSpeed = Number(difficultyEl.value);
    });

    fitCanvas();
    loop();
  </script>
</body>
</html>
